# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set ONE of these. The app reads LLM_PROVIDER to decide which client to load.
LLM_PROVIDER=gemini           # Options: gemini | openai | anthropic

# Google Gemini (default / free-tier friendly)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (optional alternative)
# OPENAI_API_KEY=your-openai-key-here

# Anthropic (optional alternative)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Uses sentence-transformers locally by default (no API key needed).
# Model: BAAI/bge-small-en-v1.5 (fast, good quality, ~130MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── Qdrant ───────────────────────────────────────────────────────────────────
# Runs in-memory by default. Set QDRANT_URL for a persistent local instance.
QDRANT_URL=                   # Leave blank for in-memory mode
QDRANT_COLLECTION=policy_docs

# ─── LangSmith Tracing ────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=rag-policy-advisor

# ─── Corpus ───────────────────────────────────────────────────────────────────
CORPUS_DIR=./policy_corpus
METADATA_FILE=./policy_corpus/metadata.json

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
